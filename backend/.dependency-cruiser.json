{
  "allowedSeverity": "warn",
  "forbidden": [
    {
      "name": "core-no-depend-on-modules",
      "severity": "error",
      "comment": "core/ 层是基础设施层，绝对不能依赖 modules/ 业务层",
      "from": { "path": "^src/core" },
      "to": { "path": "^src/modules" }
    },
    {
      "name": "repositories-no-depend-on-modules",
      "severity": "error",
      "comment": "repositories/ 层是纯数据访问层，不能反向依赖 modules/ 业务层",
      "from": { "path": "^src/repositories" },
      "to": { "path": "^src/modules" }
    },
    {
      "name": "no-cross-module-routes",
      "severity": "error",
      "comment": "模块间不能直接 import 对方的 routes/，只能通过 services/ 跨模块通信",
      "from": {
        "path": "^src/modules/([^/]+)/",
        "pathNot": "^src/modules/_registry"
      },
      "to": {
        "path": "^src/modules/([^/]+)/routes",
        "pathNot": "^src/modules/$1/routes"
      }
    },
    {
      "name": "modules-only-via-services",
      "severity": "warn",
      "comment": "任意代码不能直接依赖其他模块的非 services 代码。services/ 和同模块内部引用不受限制",
      "from": {
        "path": "^src/modules/([^/]+)/",
        "pathNot": "^src/modules/_registry"
      },
      "to": {
        "path": "^src/modules/([^/]+)/",
        "pathNot": ["^src/modules/$1/", "^src/modules/[^/]+/services/"]
      }
    }
  ],
  "options": {
    "doNotFollow": {
      "path": "node_modules"
    },
    "tsPreCompilationDeps": true,
    "tsConfig": {
      "fileName": "tsconfig.json"
    },
    "enhancedResolveOptions": {
      "exportsFields": ["exports"],
      "conditionNames": ["import", "require", "node", "default", "types"]
    }
  }
}
